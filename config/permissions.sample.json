{
  "schemaVersion": 1,
  "artifactType": "illustrative-non-executable-policy",
  "label": "Synthetic demonstration policy",
  "enforcementNote": "Illustrative policy; it is not the shipped runtime policy or a drop-in enforcement file.",
  "rulePrecedence": "deny-overrides-allow",
  "defaultEffect": "ask",
  "unattendedMode": {
    "externalEffects": "deny",
    "unknownCommands": "deny"
  },
  "pathRules": [
    {
      "effect": "deny",
      "operations": [
        "read",
        "write",
        "edit"
      ],
      "patterns": [
        "**/.env*",
        "**/auth.*",
        "**/credentials/**",
        "**/sessions/**",
        "**/transcripts/**",
        "**/browser-state/**",
        "**/.git/**",
        "**/node_modules/**"
      ]
    },
    {
      "effect": "allow",
      "operations": [
        "read"
      ],
      "patterns": [
        "<workspace>/config/**",
        "<workspace>/demo/**",
        "<workspace>/docs/**"
      ]
    }
  ],
  "commandRules": [
    {
      "effect": "allow",
      "exact": [
        "node scripts/run-demo.mjs",
        "node --test tests/demo.test.mjs",
        "node scripts/verify-demo.mjs"
      ]
    },
    {
      "effect": "deny",
      "categories": [
        "destructive-filesystem",
        "network-write",
        "package-install",
        "publish",
        "deploy",
        "account-action"
      ]
    }
  ],
  "humanApproval": {
    "requiredFor": [
      "remote-write",
      "external-write",
      "publish",
      "deploy",
      "account-action"
    ],
    "approvalIsSingleUse": true
  }
}
